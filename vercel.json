{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": "public",
  "framework": null,
  "headers": [
    {
      "source": "/(news\\.json|archive-index\\.json|news-data\\.js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=60, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/archive/(.+)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=86400, immutable" }
      ]
    }
  ]
}
